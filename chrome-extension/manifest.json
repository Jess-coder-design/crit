{
  "manifest_version": 3,
  "name": "CR!T Orange Blur",
  "version": "1.0",
  "description": "Adds an orange blur effect to webpages and highlights CR!T keywords with their colors",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": ["keywords.json", "colors.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Toggle CR!T Orange Blur"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
